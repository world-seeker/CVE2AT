	t6_and_1 [label=AND fillcolor="#FFCCCB" fontname=Helvetica shape=ellipse style=filled]
	t6_and_1 -> t6_sub_1
	t6_and_1 -> t6_cap_1
	t6_tech_2 [label="Remote Service Session Hijacking" fillcolor="#90EE90" fontname=Helvetica shape=box style=filled]
	t6_cap_2 [label="Session Hijacking" fillcolor="#FFB6C1" fontname=Helvetica shape=box style=filled]
