	t6_and_2 -> t6_tech_2
	t6_and_2 -> t6_cap_2
	t6_cwe1_or_3 [label=OR fillcolor="#FFCCCB" fontname=Helvetica shape=ellipse style=filled]
	t6_cwe1_or_3 -> t6_and_1
	t6_cwe1_or_3 -> t6_and_2
	t6_cwe_1 -> t6_cwe1_or_3
	t6_tac_or_4 [label=OR fillcolor="#FFCCCB" fontname=Helvetica shape=ellipse style=filled]
	t6_tac_or_4 -> t6_cwe_0
	t6_tac_or_4 -> t6_cwe_1
